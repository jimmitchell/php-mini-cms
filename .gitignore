# Composer
/vendor/
composer.phar
/composer        # local composer binary
/composer-setup.php  # installer script — not web-safe, delete after use

# Runtime config — contains credentials; never commit
/config.php

# Database and uploaded media (runtime data — not committed)
/data/
/content/media/
/storage/

# Generated static output — rebuilt by the CMS; not tracked
/index.html
/404.html
/feed.xml
/feed.rss
/feed.json
/sitemap.xml
/theme.min.css
/theme.critical.css
/search.json
/posts/
/page/
/pages/
/search/
/category/
/tag/

# Proxima Nova font files (commercial license — do not commit)
/fonts/ProximaNova*
/fonts/og/ProximaNova*

# Editor temp files
*.swp
*.swo
.DS_Store
Thumbs.db
.sfdx
.claude

# Claude files
CLAUDE.md
CLAUDE-*
TODO.md

# Production server nginx configs (contain real domain/cert paths)
*.nginx.conf