# Composer
/vendor/
composer.phar
/composer # local composer binary

# Runtime config — contains credentials; never commit
/config.php

# Database and uploaded media (runtime data — not committed)
/data/
/content/media/
/storage/

# Generated static output — rebuilt by the CMS; not tracked
/index.html
/404.html
/feed.xml
/feed.json
/sitemap.xml
/theme.min.css
/theme.critical.css
/search.json
/posts/
/page/
/pages/
/search/
/category/
/tag/

# Proxima Nova font files (commercial license — do not commit)
/fonts/ProximaNova*
/fonts/og/ProximaNova*

# Editor temp files
*.swp
*.swo
.DS_Store
Thumbs.db

# Claude files
CLAUDE.md
CLAUDE-*

# Production server nginx configs (contain real domain/cert paths)
*.nginx.conf