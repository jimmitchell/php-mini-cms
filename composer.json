{
    "name": "php-mini-cms/cms",
    "description": "A lightweight flat-file CMS with PHP admin panel and static HTML output",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "league/commonmark": "^2.4",
        "scrivo/highlight.php": "^9.18",
        "spomky-labs/otphp": "^11.0",
        "bacon/bacon-qr-code": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CMS\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
